# === API Keys (REQUIRED) ===
OPENAI_API_KEY=sk-your-key-here          # Required for text LLM agents
GOOGLE_API_KEY=your-google-key-here      # Required for Gemini image generation

# === LLM Configuration ===
LLM_MODEL=gpt-4o                         # Model for text agents (retriever, planner, stylist, critic)
IMAGE_MODEL=gemini-2.5-flash-image       # gemini-2.5-flash-image | gemini-3.1-flash-image-preview
IMAGE_ASPECT_RATIO=16:9                  # 1:1 | 2:3 | 3:2 | 4:3 | 16:9 | 9:16 | 21:9
IMAGE_RESOLUTION=2K                      # 512px | 1K | 2K | 4K

# === Pipeline Configuration ===
MAX_REFINEMENT_ROUNDS=3                  # Max visualizer-critic loops (1-10)
NUM_REFERENCES=5                         # Number of reference images to retrieve (1-20)

# === Paths (relative to project root) ===
OUTPUT_DIR=output
REFERENCES_DIR=references
STYLE_GUIDE_PATH=config/style_guide.md
PROMPTS_PATH=config/prompts.yaml

# === Logging ===
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
